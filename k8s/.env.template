# Kubernetes Secret Configuration Template
# Copy this file to .env.k8s and fill in your actual values

# ============ Database Configuration ============
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@postgres-host:5432/database

# Database Encryption Key (generate with: openssl rand -base64 32)
KEY_VAULTS_SECRET=

# ============ NextAuth Configuration ============
# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXT_AUTH_SECRET=

# ============ S3/MinIO Configuration ============
# S3 Endpoint (internal service name or external URL)
S3_ENDPOINT=http://minio-service:9000

# S3 Public Domain (accessible from outside the cluster)
S3_PUBLIC_DOMAIN=https://s3.omniverseai.net

# S3 Credentials
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============ Optional: AI Provider Keys ============
# OpenAI API Key (required for embeddings)
# OPENAI_API_KEY=sk-

# Anthropic API Key
# ANTHROPIC_API_KEY=

# Google AI API Key
# GOOGLE_API_KEY=

# ============ Optional: Email Configuration ============
# Email service credentials (if using email verification)
# EMAIL_FROM=noreply@omniverseai.net
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
